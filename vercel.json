{
  "version": 2,
  "builds": [
    {
      "src": "backend/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["backend/views/**", "backend/public/**"]
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "backend/index.js" }],
  "env": { "NODE_ENV": "production" }
}
